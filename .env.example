# Database
DATABASE_URL=

# Auth
JWT_SECRET=

# Redis (email queue)
REDIS_URL=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=PitchOff <onboarding@resend.dev>

# Cloudinary (pitch deck uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix (default: pitchoff/pitch-decks)
CLOUDINARY_PITCH_DECK_FOLDER=pitchoff/pitch-decks

# Seed
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin

# Coolify / production
# Build:  pnpm run build          (generates Prisma client + compiles TS)
# Start:  pnpm run start:prod     (runs migrations, then the server)
# Seed:   pnpm run seed           (run manually on first deploy only)
